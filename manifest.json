{
    "name": "YouTube Ad Blocker",
    "version": "1.0.0",
    "description": "Block YouTube Ads",
    "manifest_version": 3,
    "author": "Apoorva Verma",
    "content_scripts": [
        {
          "matches": ["https://www.youtube.com/*"],
          "js": ["script.js"]
        }
      ],
      
    "action":{
        "default_popup": "index.html",
        "default_title": "Block Youtube Ads"
    },
    "icons": {
        "16": "./images/icon.png",
        "48": "./images/icon.png",
        "128": "./images/icon.png"
      }
}